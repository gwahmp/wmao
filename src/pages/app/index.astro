---
import MemberLayout from "../../layouts/MemberLayout.astro";
const version = Date.now();
const frontmatter = {
  title: "App | Wikimint digital growth platform",
  description: "Access your Wikimint member dashboard to manage your profile, credits, Growth Pool portfolio, marketing tools, referrals, earnings, and account settings from one place.",
  // canonical: "/about",
  image: "/assets/images/others/wikimint-all-in-one-marketing-platform.webp",
  tags: ["about", "business", "finance"],
  author: "Wikimint Team",
  disableAds: true,
};
