---
import "../styles/global.css";
import "../styles/dashboard.css";
import DashMenu from "../components/DashMenu.astro";
import DashSidebar from "../components/DashSidebar.astro";
import AuthVisibility from "../components/AuthVisibility.astro";
import Spinner from "../components/Spinner.astro";

const {
    frontmatter = {}
} = Astro.props;

const {
    title = "Member Area",
    description = "",
    image = "/assets/images/business-motivation-marketing-strategy-personal-finance-strategy.webp",
    noindex = false,
    disableAds = false,
    tags = [],
    author = "Wikimint Team"
} = frontmatter;

const version = Date.now();

const siteUrl = Astro.site?.toString().replace(/\/$/, "");
const absoluteImage =
  image?.startsWith("http")
    ? image
    : `${siteUrl}${image}`;
    
const url = Astro.site
  ? new URL(Astro.url.pathname.replace(/\.html$/, ""), Astro.site).toString()
  : undefined;

  const truncate = (str: string, len: number) =>
  str.length > len ? str.slice(0, len).trim() : str;

  const seoTitle = truncate(title, 90);
const seoDescription = truncate(description, 180);


const {
  ogType,
} = Astro.props;
const finalOgType = ogType ?? "website";

const {
  publishedTime,
  modifiedTime
} = Astro.props;
---

<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />


    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    {url ? (
      <link rel="canonical" href={url} />
    ) : null}

<link rel="preload" as="image" href={absoluteImage} />
<meta name="robots" content={noindex 
  ? "noindex, nofollow" 
  : "index, follow, max-image-preview:large"} />
    
    <meta name="author" content="Wikimint" />

{/* Open Graph */}
<meta property="og:type" content={finalOgType} />
{ogType === "article" && (
  <>
  <meta property="article:publisher" content="https://www.facebook.com/wikimintofficial" />
    <meta property="article:author" content="https://sk.wikimint.com" />
  </>
)}
<meta property="og:site_name" content="Wikimint" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />

{url ? (
  <meta property="og:url" content={url} />
) : null}

<meta property="og:image" content={absoluteImage} />
<meta property="og:image:width" content="800" />
<meta property="og:image:type" content="image/webp" />

{/* Twitter Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@wikimint" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImage} />
{ogType === "article" && (
  <>
<meta name="twitter:creator" content="@selvakumarankri" />
</>
)}
{publishedTime && (
  <meta
    property="article:published_time"
    content={new Date(publishedTime).toISOString()}
  />
  )}
  
  {modifiedTime && (
  <meta
    property="article:modified_time"
    content={new Date(modifiedTime).toISOString()}
  />
  )}


{/* ✅ Feed Discovery (Recommended Order) */}
<link
  rel="alternate"
  type="application/atom+xml"
  title="Wikimint Blog"
  href="/atom.xml" />

<link
  rel="alternate"
  type="application/rss+xml"
  title="Wikimint Blog RSS"
  href="/rss.xml" />

  
{import.meta.env.PROD && (
    <>
    <!-- Google tag (gtag.js) -->
  <script is:inline async data-consent="analytics" type="text/plain" data-src="https://www.googletagmanager.com/gtag/js?id=G-HBNN5MVE39"></script>
  <script is:inline data-consent="analytics" type="text/plain">
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
  
    gtag('config', 'G-HBNN5MVE39');
  </script>
  
     </>
    )}
  
  
  {/*<script is:inline src="http://localhost:8080/dist/wm-cookie-consent.min.js"></script>*/}
  
  <script is:inline src="https://cdn.jsdelivr.net/gh/wikimint/wm-cookie-consent@1.0.13/dist/wm-cookie-consent.min.js"></script>
      
    {/*  
     <link href={`/assets/css/dashboard.css?v=${version}`} rel="stylesheet"> 
     */}

  
</head>

<body>
  <AuthVisibility />
  <script is:inline src={`/assets/js/auth.js?v=${version}`} defer/>

<div
    class="
        md:flex
        md:h-screen
        md:overflow-hidden
    ">

    <DashMenu />

    <main
        class="
            flex-1
            md:h-screen
            md:overflow-y-auto
            p-6
        ">

        <div
    class="
        flex
        flex-col
        lg:flex-row
        gap-6
    ">

    <article
        class="
            flex-1
            min-w-0
        ">

        <Spinner/>
        <slot />

    </article>

    <aside
        class="
            w-full
            lg:w-80
            shrink-0
        ">

        <DashSidebar />

    </aside>

</div>

    </main>

</div>




<script is:inline src={`/assets/js/member.js?v=${version}`} defer/></script>
<script is:inline src={`/assets/js/dashboard.js?v=${version}`} defer></script>



</body>

</html>