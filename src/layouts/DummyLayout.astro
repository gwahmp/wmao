---
const { title, description } = Astro.props;
const version = Date.now();
import AuthVisibility from "../components/AuthVisibility.astro";

---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Basic Meta -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- No Index -->
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />

    <!-- Optional -->
    <meta name="theme-color" content="#ffffff" />

    <!-- Extra Head -->
    <slot name="head" />
  </head>

  <body>
    <AuthVisibility />
    <script is:inline src={`/assets/js/auth.js?v=${version}`} defer/>

    <main class="dummy-layout">
      <slot />
    </main>

  </body>
</html>